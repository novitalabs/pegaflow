[global]
ioengine=sync
direct=1
bs=4k
size=64m
numjobs=4
runtime=10
time_based
group_reporting
rw=write

[1path_1shard_write]
directory=/tmp/fio-ssd-0
nrfiles=1
stonewall

[1path_2shard_write]
directory=/tmp/fio-ssd-0
nrfiles=2
stonewall

[2path_1shard_write]
directory=/tmp/fio-ssd-1
nrfiles=1
stonewall

[2path_2shard_write]
directory=/tmp/fio-ssd-1
nrfiles=2
stonewall
